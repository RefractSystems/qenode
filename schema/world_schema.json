{
  "$defs": {
    "Address": {
      "$id": "Address.json",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "oneOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "pattern": "^(0x[0-9a-fA-F]+|none|sysbus)$",
          "type": "string"
        }
      ],
      "type": "string"
    },
    "Coordinate": {
      "$id": "Coordinate.json",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      },
      "required": [
        "x",
        "y",
        "z"
      ],
      "type": "object"
    },
    "Cpu": {
      "$id": "Cpu.json",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "isa": {
          "type": "string"
        },
        "memory": {
          "type": "string"
        },
        "mmu_type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "type"
      ],
      "type": "object"
    },
    "Machine": {
      "$id": "Machine.json",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "cpus": {
          "items": {
            "$ref": "#/$defs/Cpu"
          },
          "type": "array"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "Node": {
      "$id": "Node.json",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "name": {
          "$ref": "#/$defs/NodeID"
        },
        "role": {
          "anyOf": [
            {
              "const": "Cyber",
              "type": "string"
            },
            {
              "const": "Physics",
              "type": "string"
            }
          ]
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "NodeID": {
      "$id": "NodeID.json",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "oneOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "string"
        }
      ],
      "type": "string"
    },
    "Protocol": {
      "$id": "Protocol.json",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "Supported inter-node communication protocols.",
      "pattern": "^(Ethernet|Uart|CanFd|Spi|FlexRay|Lin|Rf802154|RfHci|eth|uart|canfd|spi|flexray|lin|rf802154|rfhci|ethernet|reference-link)$",
      "type": "string"
    },
    "RecordUnknown": {
      "$id": "RecordUnknown.json",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {},
      "type": "object",
      "unevaluatedProperties": {}
    },
    "Resource": {
      "$id": "Resource.json",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "address": {
          "$ref": "#/$defs/Address"
        },
        "container": {
          "type": "string"
        },
        "interrupts": {
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "integer"
              }
            ]
          },
          "type": "array"
        },
        "name": {
          "$ref": "#/$defs/NodeID"
        },
        "parent": {
          "type": "string"
        },
        "properties": {
          "$ref": "#/$defs/RecordUnknown"
        },
        "renode_type": {
          "type": "string"
        },
        "size": {
          "$ref": "#/$defs/Address"
        },
        "type": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "Topology": {
      "$id": "Topology.json",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "global_seed": {
          "type": "string"
        },
        "links": {
          "items": {
            "$ref": "#/$defs/WireLink"
          },
          "type": "array"
        },
        "max_messages_per_node_per_quantum": {
          "maximum": 4294967295,
          "minimum": 0,
          "type": "integer"
        },
        "nodes": {
          "items": {
            "$ref": "#/$defs/Node"
          },
          "type": "array"
        },
        "transport": {
          "anyOf": [
            {
              "const": "zenoh",
              "type": "string"
            },
            {
              "const": "unix",
              "type": "string"
            }
          ]
        },
        "wireless": {
          "$ref": "#/$defs/WirelessMedium"
        }
      },
      "type": "object"
    },
    "WireLink": {
      "$id": "WireLink.json",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "baud": {
          "maximum": 4294967295,
          "minimum": 0,
          "type": "integer"
        },
        "name": {
          "type": "string"
        },
        "nodes": {
          "items": {
            "$ref": "#/$defs/NodeID"
          },
          "type": "array"
        },
        "type": {
          "$ref": "#/$defs/Protocol",
          "alias": "type"
        }
      },
      "required": [
        "name",
        "type",
        "nodes"
      ],
      "type": "object"
    },
    "WirelessMedium": {
      "$id": "WirelessMedium.json",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "max_range_m": {
          "type": "number"
        },
        "medium": {
          "type": "string"
        },
        "nodes": {
          "items": {
            "$ref": "#/$defs/WirelessNode"
          },
          "type": "array"
        }
      },
      "required": [
        "medium",
        "max_range_m",
        "nodes"
      ],
      "type": "object"
    },
    "WirelessNode": {
      "$id": "WirelessNode.json",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "initial_position": {
          "$ref": "#/$defs/Coordinate"
        },
        "name": {
          "$ref": "#/$defs/NodeID"
        }
      },
      "required": [
        "name",
        "initial_position"
      ],
      "type": "object"
    },
    "World": {
      "$id": "World.json",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "machine": {
          "$ref": "#/$defs/Machine"
        },
        "memory": {
          "items": {
            "$ref": "#/$defs/Resource"
          },
          "type": "array"
        },
        "nodes": {
          "items": {
            "$ref": "#/$defs/Node"
          },
          "type": "array"
        },
        "peripherals": {
          "items": {
            "$ref": "#/$defs/Resource"
          },
          "type": "array"
        },
        "topology": {
          "$ref": "#/$defs/Topology"
        }
      },
      "type": "object"
    },
    "WorldSchema": {
      "$id": "WorldSchema.json",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "properties": {
        "machine": {
          "$ref": "#/$defs/Machine"
        },
        "memory": {
          "items": {
            "$ref": "#/$defs/Resource"
          },
          "type": "array"
        },
        "nodes": {
          "items": {
            "$ref": "#/$defs/Node"
          },
          "type": "array"
        },
        "peripherals": {
          "items": {
            "$ref": "#/$defs/Resource"
          },
          "type": "array"
        },
        "topology": {
          "$ref": "#/$defs/Topology"
        }
      },
      "type": "object"
    }
  },
  "$id": "virtmcu_world.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}