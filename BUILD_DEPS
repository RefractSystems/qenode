# virtmcu Project Dependency Versions
# Centralized version definitions for build scripts, Docker, and documentation.

# Docker Registry Configuration
VIRTMCU_IMAGE_REGISTRY=ghcr.io/refractsystems/virtmcu
VIRTMCU_DEVENV_IMAGE=virtmcu-devenv
VIRTMCU_CI_IMAGE=virtmcu-ci

# QEMU emulator base
# Tag v11.0.0 in https://gitlab.com/qemu-project/qemu.git
QEMU_VERSION=11.0.0

# Zenoh federation bus (Zenoh-C and Python eclipse-zenoh)
# Used for deterministic multi-node networking and clock synchronization.
ZENOH_VERSION=1.9.0

# ARM Generic FDT patch series
# 33-patch series enabling FDT-based machine initialization.
ARM_GENERIC_FDT_PATCH_SET=v3

# CMake build system
CMAKE_VERSION=4.3.1
MESON_VERSION=1.8.0

# Rust toolchain
RUST_VERSION=1.95.0
BINDGEN_VERSION=0.72.1

# FlatBuffers serialization library
FLATBUFFERS_VERSION=25.12.19
FLATCC_VERSION=0.6.1

# SystemC and related adapters
SYSTEMC_VERSION=2.3.3
LIBSYSTEMCTLM_SOC_COMMIT=7aba4f60e382581060c982976010674c33bdc442

# Debian base image codename — single-line upgrade path
DEBIAN_CODENAME=trixie

# Node.js major version for devtools
NODE_VERSION=24
NPM_VERSION=11.14.1

# ARM GNU Toolchain — downloaded from developer.arm.com official releases
# Pinned independently of Debian apt to guarantee cross-compiler reproducibility.
# Binary fidelity (RFC-0006) requires the toolchain to be bit-for-bit stable.
ARM_TOOLCHAIN_VERSION=13.3.rel1

# CI Tooling
HADOLINT_VERSION=2.14.0
ACTIONLINT_VERSION=1.7.12
YAMLLINT_VERSION=1.37.1
MDBOOK_VERSION=0.4.52
MDBOOK_MERMAID_VERSION=0.17.0
MDBOOK_PDF_VERSION=0.1.13
CARGO_TARPAULIN_VERSION=0.35.4

# Cargo binary installer (pinned to prevent silent installer updates)
CARGO_BINSTALL_VERSION=1.10.4
