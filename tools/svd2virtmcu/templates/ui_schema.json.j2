{
  "world_id": "{{ world_id }}",
  "nodes": {
    "{{ node_id }}": {
      "name": "Arm PID Controller",
      "controls": [
        {% for c in controls %}
        {
          "id": "{{ c.id }}",
          "label": "{{ c.label }}",
          "offset": {{ c.offset }},
          "type": "{{ c.type }}",
          "min": {{ c.min }},
          "max": {{ c.max }},
          "step": {{ c.step }},
          "unit": "{{ c.unit }}",
          "default": {{ c.default }}
        }{% if not loop.last %},{% endif %}
        {% endfor %}
      ],
      "telemetry": [
        {% for t in telemetry %}
        {
          "id": "{{ t.id }}",
          "label": "{{ t.label }}",
          "topic": "{{ t.topic }}",
          "json_path": "{{ t.json_path }}",
          "type": "{{ t.type }}",
          "unit": "{{ t.unit }}"
        }{% if not loop.last %},{% endif %}
        {% endfor %}
      ]
    }
  }
}
