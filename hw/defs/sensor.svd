<?xml version="1.0" encoding="utf-8"?>
<device schemaVersion="1.1" xmlns:xs="http://www.w3.org/2001/XMLSchema-instance" xs:noNamespaceSchemaLocation="CMSIS-SVD.xsd">
  <vendor>VirtMCU</vendor>
  <name>Sensor</name>
  <description>VirtMCU Sensor Peripheral</description>
  <addressUnitBits>8</addressUnitBits>
  <width>32</width>
  <size>32</size>
  <peripherals>
    <peripheral>
      <name>SENSOR</name>
      <baseAddress>0x0B000000</baseAddress>
      <addressBlock>
        <offset>0</offset>
        <size>0x100</size>
        <usage>registers</usage>
      </addressBlock>
      <registers>
        <register>
          <name>ID</name>
          <description>Sensor ID</description>
          <addressOffset>0x00</addressOffset>
        </register>
        <register>
          <name>DATA_SIZE</name>
          <description>Data size (number of elements)</description>
          <addressOffset>0x04</addressOffset>
        </register>
        <register>
          <name>GO</name>
          <description>Trigger data latching</description>
          <addressOffset>0x08</addressOffset>
        </register>
        <register>
          <name>READY</name>
          <description>Ready status (1 = new data available)</description>
          <addressOffset>0x0C</addressOffset>
        </register>
        <register>
          <name>DATA</name>
          <description>Double-precision data payload</description>
          <addressOffset>0x10</addressOffset>
          <size>64</size>
        </register>
      </registers>
    </peripheral>
  </peripherals>
</device>
