from __future__ import annotations

import flatbuffers
import numpy as np

import typing
from virtmcu.core.Protocol import Protocol

uoffset: typing.TypeAlias = flatbuffers.number_types.UOffsetTFlags.py_type

class CoordMessage(object):
  @classmethod
  def GetRootAs(cls, buf: bytes, offset: int) -> CoordMessage: ...
  @classmethod
  def GetRootAsCoordMessage(cls, buf: bytes, offset: int) -> CoordMessage: ...
  def Init(self, buf: bytes, pos: int) -> None: ...
  def SrcNodeId(self) -> int: ...
  def DstNodeId(self) -> int: ...
  def DeliveryVtimeNs(self) -> int: ...
  def SequenceNumber(self) -> int: ...
  def Protocol(self) -> typing.Literal[Protocol.Ethernet, Protocol.Uart, Protocol.Spi, Protocol.CanFd, Protocol.FlexRay, Protocol.Lin, Protocol.Rf802154, Protocol.RfHci, Protocol.Control]: ...
  def Payload(self, i: int) -> typing.List[int]: ...
  def PayloadAsNumpy(self) -> np.ndarray: ...
  def PayloadLength(self) -> int: ...
  def PayloadIsNone(self) -> bool: ...
def CoordMessageStart(builder: flatbuffers.Builder) -> None: ...
def Start(builder: flatbuffers.Builder) -> None: ...
def CoordMessageAddSrcNodeId(builder: flatbuffers.Builder, srcNodeId: int) -> None: ...
def CoordMessageAddDstNodeId(builder: flatbuffers.Builder, dstNodeId: int) -> None: ...
def CoordMessageAddDeliveryVtimeNs(builder: flatbuffers.Builder, deliveryVtimeNs: int) -> None: ...
def CoordMessageAddSequenceNumber(builder: flatbuffers.Builder, sequenceNumber: int) -> None: ...
def CoordMessageAddProtocol(builder: flatbuffers.Builder, protocol: typing.Literal[Protocol.Ethernet, Protocol.Uart, Protocol.Spi, Protocol.CanFd, Protocol.FlexRay, Protocol.Lin, Protocol.Rf802154, Protocol.RfHci, Protocol.Control]) -> None: ...
def CoordMessageAddPayload(builder: flatbuffers.Builder, payload: uoffset) -> None: ...
def CoordMessageStartPayloadVector(builder: flatbuffers.Builder, num_elems: int) -> uoffset: ...
def StartPayloadVector(builder: flatbuffers.Builder, num_elems: int) -> uoffset: ...
def CoordMessageEnd(builder: flatbuffers.Builder) -> uoffset: ...
def End(builder: flatbuffers.Builder) -> uoffset: ...

