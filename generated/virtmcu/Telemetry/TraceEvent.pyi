from __future__ import annotations

import flatbuffers
import numpy as np

import typing
from Virtmcu.Telemetry.TraceEventType import TraceEventType

uoffset: typing.TypeAlias = flatbuffers.number_types.UOffsetTFlags.py_type

class TraceEvent(object):
  @classmethod
  def GetRootAs(cls, buf: bytes, offset: int) -> TraceEvent: ...
  @classmethod
  def GetRootAsTraceEvent(cls, buf: bytes, offset: int) -> TraceEvent: ...
  def Init(self, buf: bytes, pos: int) -> None: ...
  def TimestampNs(self) -> int: ...
  def Type(self) -> typing.Literal[TraceEventType.CPU_STATE, TraceEventType.IRQ, TraceEventType.PERIPHERAL, TraceEventType.POWER_STATE]: ...
  def Id(self) -> int: ...
  def Value(self) -> int: ...
  def DeviceName(self) -> str | None: ...
  def PowerUw(self) -> int: ...
def TraceEventStart(builder: flatbuffers.Builder) -> None: ...
def Start(builder: flatbuffers.Builder) -> None: ...
def TraceEventAddTimestampNs(builder: flatbuffers.Builder, timestampNs: int) -> None: ...
def AddTimestampNs(builder: flatbuffers.Builder, timestampNs: int) -> None: ...
def TraceEventAddType(builder: flatbuffers.Builder, type: typing.Literal[TraceEventType.CPU_STATE, TraceEventType.IRQ, TraceEventType.PERIPHERAL, TraceEventType.POWER_STATE]) -> None: ...
def AddType(builder: flatbuffers.Builder, type: typing.Literal[TraceEventType.CPU_STATE, TraceEventType.IRQ, TraceEventType.PERIPHERAL, TraceEventType.POWER_STATE]) -> None: ...
def TraceEventAddId(builder: flatbuffers.Builder, id: int) -> None: ...
def AddId(builder: flatbuffers.Builder, id: int) -> None: ...
def TraceEventAddValue(builder: flatbuffers.Builder, value: int) -> None: ...
def AddValue(builder: flatbuffers.Builder, value: int) -> None: ...
def TraceEventAddDeviceName(builder: flatbuffers.Builder, deviceName: uoffset) -> None: ...
def AddDeviceName(builder: flatbuffers.Builder, deviceName: uoffset) -> None: ...
def TraceEventAddPowerUw(builder: flatbuffers.Builder, powerUw: int) -> None: ...
def AddPowerUw(builder: flatbuffers.Builder, powerUw: int) -> None: ...
def TraceEventEnd(builder: flatbuffers.Builder) -> uoffset: ...
def End(builder: flatbuffers.Builder) -> uoffset: ...

