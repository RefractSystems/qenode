from __future__ import annotations

import flatbuffers
import numpy as np

import typing

uoffset: typing.TypeAlias = flatbuffers.number_types.UOffsetTFlags.py_type

class CanFdFrame(object):
  @classmethod
  def GetRootAs(cls, buf: bytes, offset: int) -> CanFdFrame: ...
  @classmethod
  def GetRootAsCanFdFrame(cls, buf: bytes, offset: int) -> CanFdFrame: ...
  def Init(self, buf: bytes, pos: int) -> None: ...
  def DeliveryVtimeNs(self) -> int: ...
  def CanId(self) -> int: ...
  def Flags(self) -> int: ...
  def Data(self, i: int) -> typing.List[int]: ...
  def DataAsNumpy(self) -> np.ndarray: ...
  def DataLength(self) -> int: ...
  def DataIsNone(self) -> bool: ...
def CanFdFrameStart(builder: flatbuffers.Builder) -> None: ...
def Start(builder: flatbuffers.Builder) -> None: ...
def CanFdFrameAddDeliveryVtimeNs(builder: flatbuffers.Builder, deliveryVtimeNs: int) -> None: ...
def CanFdFrameAddCanId(builder: flatbuffers.Builder, canId: int) -> None: ...
def CanFdFrameAddFlags(builder: flatbuffers.Builder, flags: int) -> None: ...
def CanFdFrameAddData(builder: flatbuffers.Builder, data: uoffset) -> None: ...
def CanFdFrameStartDataVector(builder: flatbuffers.Builder, num_elems: int) -> uoffset: ...
def StartDataVector(builder: flatbuffers.Builder, num_elems: int) -> uoffset: ...
def CanFdFrameEnd(builder: flatbuffers.Builder) -> uoffset: ...
def End(builder: flatbuffers.Builder) -> uoffset: ...

